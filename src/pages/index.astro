---
const title = 'SVG to CSS URL Encoder';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
  </head>
  <body>
    <div class="wrapper">
      <header class="header">
        <h1>{title}</h1>
        <p class="tagline">Encode SVG for use in CSS <code>background-image</code>, <code>border-image</code>, or <code>mask</code></p>
      </header>

      <main>
        <section class="panel">
          <div class="options">
            <span class="options__label">External quotes:</span>
            <label class="options__radio">
              <input type="radio" value="single" name="quotes" class="options__input" />
              <span>single</span>
            </label>
            <label class="options__radio">
              <input type="radio" value="double" name="quotes" class="options__input" checked />
              <span>double</span>
            </label>
          </div>
          <div class="about__content">
              <p>SVG in CSS via data URI works in all browsers only when encoded. This tool uses <code>encodeURIComponent()</code> so the result works everywhere.</p>
              <p>SVG must have <code>xmlns='http://www.w3.org/2000/svg'</code>. If missing, it is added automatically.</p>
              <p>Encoded SVG can be used in <code>background</code>, <code>border-image</code>, or <code>mask</code>.</p>
            </div>
        </section>
        <section class="containers">
          <div class="container">
            <div class="container__head">
              <h2>Insert SVG</h2>
              <div class="container__actions">
                <button type="button" class="btn btn--ghost" id="example-btn">Example</button>
                <button type="button" class="btn btn--ghost" id="clear-btn">Clear</button>
              </div>
            </div>
            <textarea name="init" id="init" spellcheck="false" placeholder="Paste or drop SVG here…" rows="8"></textarea>
          </div>

          <div class="container">
            <div class="container__head">
              <h2>Encoded result</h2>
              <button type="button" class="btn btn--ghost" id="copy-result-button" title="Copy to clipboard">Copy</button>
            </div>
            <textarea name="result" id="result" spellcheck="false" rows="8" placeholder="Encoded output or paste here to decode"></textarea>
            <p class="tip">Paste encoded SVG here to decode it back.</p>
          </div>
        </section>

        <section class="containers">
          <div class="container">
            <div class="container__head">
              <h2>Ready for CSS</h2>
              <button type="button" class="btn btn--ghost" id="copy-css-result-button" title="Copy to clipboard">Copy</button>
            </div>
            <textarea name="result-css" id="result-css" spellcheck="false" readonly rows="4"></textarea>
          </div>

          <div class="container container--preview">
            <div class="container__head">
              <h2>Preview</h2>
              <div class="contrast-buttons" aria-label="Preview background">
                <span class="contrast-buttons__label">Background:</span>
                <button type="button" class="contrast-button contrast-button--white" data-color="white" title="White"><span class="sr-only">White</span></button>
                <button type="button" class="contrast-button contrast-button--silver" data-color="silver" title="Silver"><span class="sr-only">Silver</span></button>
                <button type="button" class="contrast-button contrast-button--black" data-color="black" title="Black"><span class="sr-only">Black</span></button>
              </div>
            </div>
            <div class="demo-wrapper" id="demo-wrapper">
              <div id="demo" class="demo"></div>
            </div>
          </div>
        </section>
      </main>
    </div>

    <div id="dropzone" class="dropzone" aria-hidden="true">
      <span class="dropzone__text">Drop SVG file here</span>
    </div>

    <script>
      const doc = document;
      const initTextarea = doc.getElementById('init') as HTMLTextAreaElement;
      const resultTextarea = doc.getElementById('result') as HTMLTextAreaElement;
      const resultCssTextarea = doc.getElementById('result-css') as HTMLTextAreaElement;
      const resultDemo = doc.getElementById('demo') as HTMLDivElement;
      const demoWrapper = doc.getElementById('demo-wrapper') as HTMLDivElement;
      const contrastButtons = doc.querySelectorAll<HTMLElement>('.contrast-button');
      const dropzoneEl = doc.getElementById('dropzone');

      const symbols = /[\r\n%#()<>?[\\\]^`{|}]/g;
      const quotesInputChecked = doc.querySelector<HTMLInputElement>('.options__input:checked');
      let externalQuotesValue = quotesInputChecked?.value ?? 'double';

      function getQuotes() {
        const d = '"';
        const s = "'";
        return {
          level1: externalQuotesValue === 'double' ? d : s,
          level2: externalQuotesValue === 'double' ? s : d
        };
      }

      let quotes = getQuotes();

      function addNameSpace(data) {
        if (data.indexOf('http://www.w3.org/2000/svg') < 0) {
          data = data.replace(/<svg/g, `<svg xmlns=${quotes.level2}http://www.w3.org/2000/svg${quotes.level2}`);
        }
        return data;
      }

      function encodeSVG(data) {
        if (externalQuotesValue === 'double') {
          data = data.replace(/"/g, "'");
        } else {
          data = data.replace(/'/g, '"');
        }
        data = data.replace(/>\s{1,}</g, '><');
        data = data.replace(/\s{2,}/g, ' ');
        return data.replace(symbols, encodeURIComponent);
      }

      function getResults() {
        if (!initTextarea.value.trim()) {
          resultCssTextarea.value = '';
          resultDemo.setAttribute('style', '');
          return;
        }
        const namespaced = addNameSpace(initTextarea.value);
        const escaped = encodeSVG(namespaced);
        resultTextarea.value = escaped;
        const resultCss = `background-image: url(${quotes.level1}data:image/svg+xml,${escaped}${quotes.level1});`;
        resultCssTextarea.value = resultCss;
        resultDemo.setAttribute('style', resultCss);
      }

      initTextarea.addEventListener('input', getResults);

      resultTextarea.addEventListener('input', () => {
        const value = resultTextarea.value.trim()
          .replace(/background-image:\s{0,}url\(/, '')
          .replace(/["']{0,}data:image\/svg\+xml,/, '')
          .replace(/["']\);{0,}$/, '');
        initTextarea.value = decodeURIComponent(value);
        getResults();
      });

      doc.querySelectorAll<HTMLInputElement>('.options__input').forEach((input) => {
        input.addEventListener('change', function () {
          externalQuotesValue = this.value;
          quotes = getQuotes();
          getResults();
        });
      });

      doc.getElementById('example-btn')!.addEventListener('click', () => {
        initTextarea.value = `<svg viewBox="0 0 24 24">
  <path fill="#a78bfa" d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
</svg>`;
        getResults();
      });

      doc.getElementById('clear-btn')!.addEventListener('click', () => {
        initTextarea.value = '';
        resultTextarea.value = '';
        resultCssTextarea.value = '';
        resultDemo.setAttribute('style', '');
        getResults();
      });

      let contrastButtonCurrent: HTMLElement | null = null;
      contrastButtons.forEach((button) => {
        if (!contrastButtonCurrent) {
          contrastButtonCurrent = button;
          button.classList.add('contrast-button--current');
          demoWrapper.style.background = button.dataset.color ?? 'white';
        }
        button.addEventListener('click', function (this: HTMLElement) {
          contrastButtonCurrent?.classList.remove('contrast-button--current');
          contrastButtonCurrent = this;
          this.classList.add('contrast-button--current');
          demoWrapper.style.background = this.dataset.color ?? 'white';
        });
      });

      async function copyToClipboard(text) {
        try {
          await navigator.clipboard.writeText(text);
          return true;
        } catch {
          return false;
        }
      }

      doc.getElementById('copy-result-button')!.addEventListener('click', () => {
        const text = resultTextarea.value;
        if (text) copyToClipboard(text);
      });

      doc.getElementById('copy-css-result-button')!.addEventListener('click', () => {
        const text = resultCssTextarea.value;
        if (text) copyToClipboard(text);
      });

      if (dropzoneEl) {
        doc.addEventListener('dragover', (e) => {
          e.preventDefault();
          dropzoneEl.classList.add('dropzone--active');
        });
        dropzoneEl.addEventListener('dragleave', () => {
          dropzoneEl.classList.remove('dropzone--active');
        });
        dropzoneEl.addEventListener('drop', (e) => {
          e.preventDefault();
          const file = e.dataTransfer?.files[0];
          if (file?.type === 'image/svg+xml') {
            const reader = new FileReader();
            reader.onload = () => {
              initTextarea.value = (reader.result as string) ?? '';
              getResults();
            };
            reader.readAsText(file);
          }
          dropzoneEl.classList.remove('dropzone--active');
        });
      }
    </script>
  </body>
</html>

<style is:global>
  :root {
    --bg: #0f0f12;
    --surface: #18181c;
    --border: #2a2a30;
    --text: #e4e4e7;
    --text-muted: #a1a1aa;
    --accent: #a78bfa;
    --accent-hover: #c4b5fd;
    --code-bg: #27272a;
    --white: #ffffff;
    --silver: #c0c0c0;
    --black: #0a0a0a;
  }

  *, *::before, *::after { box-sizing: border-box; }

  html {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    font-size: 16px;
    line-height: 1.5;
    color: var(--text);
    background: var(--bg);
  }

  body { margin: 0; min-height: 100vh; }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  code {
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, monospace;
    font-size: 0.9em;
    padding: 0.15em 0.4em;
    background: var(--code-bg);
    border-radius: 4px;
    color: var(--accent);
  }

  .wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .header h1 {
    font-size: clamp(1.75rem, 4vw, 2.25rem);
    font-weight: 700;
    margin: 0 0 0.5rem;
    letter-spacing: -0.02em;
  }

  .tagline {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .tagline code { font-size: 0.85em; }

  .panel {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 1rem 2rem;
    margin-bottom: 2rem;
  }

  .options {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .options__label { color: var(--text-muted); font-size: 0.9rem; }
  .options__radio { cursor: pointer; font-size: 0.9rem; }
  .options__radio span { text-decoration: underline; text-underline-offset: 2px; }
  .options__input:checked + span { text-decoration: none; color: var(--accent); }

  .about {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--surface);
  }

  .about__summary {
    padding: 0.6rem 1rem;
    cursor: pointer;
    list-style: none;
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .about__summary::-webkit-details-marker { display: none; }
  .about__summary::before { content: '▶ '; font-size: 0.6em; }
  .about[open] .about__summary::before { content: '▼ '; }

  .about__content {
    padding: 0 1rem 1rem;
    border-top: 1px solid var(--border);
  }
  .about__content p { margin: 0.75rem 0 0; font-size: 0.9rem; color: var(--text-muted); }
  .about__content p:first-child { margin-top: 0.75rem; }

  .containers {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  @media (max-width: 900px) {
    .containers { grid-template-columns: 1fr; }
  }

  .container {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1rem 1.25rem;
    display: flex;
    flex-direction: column;
  }

  .container__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .container__actions {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .container h2 {
    margin: 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--text);
  }

  .btn {
    font: inherit;
    font-size: 0.85rem;
    padding: 0.35rem 0.75rem;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    background: transparent;
    color: var(--accent);
  }
  .btn:hover { color: var(--accent-hover); }

  textarea {
    width: 100%;
    min-height: 140px;
    padding: 0.75rem;
    font-family: ui-monospace, 'Cascadia Code', 'Source Code Pro', Menlo, monospace;
    font-size: 13px;
    line-height: 1.5;
    color: var(--text);
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    resize: vertical;
  }
  textarea::placeholder { color: var(--text-muted); opacity: 0.7; }
  textarea[readonly] { opacity: 0.95; }

  .tip {
    margin: 0.5rem 0 0;
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .container--preview .container__head {
    flex-wrap: wrap;
  }

  .contrast-buttons {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .contrast-buttons__label {
    font-size: 0.85rem;
    color: var(--text-muted);
  }

  .contrast-button {
    width: 28px;
    height: 28px;
    padding: 0;
    border: 2px solid var(--border);
    border-radius: 50%;
    cursor: pointer;
    transition: box-shadow 0.15s, transform 0.1s;
  }
  .contrast-button:hover { transform: scale(1.08); }
  .contrast-button--current { box-shadow: 0 0 0 2px var(--bg), 0 0 0 4px var(--accent); }
  .contrast-button--white { background: var(--white); }
  .contrast-button--silver { background: var(--silver); }
  .contrast-button--black { background: var(--black); }

  .demo-wrapper {
    margin-top: 0.5rem;
    border: 1px dashed var(--border);
    border-radius: 8px;
    min-height: 160px;
    background: white;
  }

  .demo {
    width: 100%;
    min-height: 160px;
    background-repeat: no-repeat;
    background-position: center;
    background-size: contain;
  }

  .dropzone {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(15, 15, 18, 0.85);
    backdrop-filter: blur(8px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
  }

  .dropzone--active {
    opacity: 1;
    pointer-events: all;
  }

  .dropzone__text {
    font-size: 1.1rem;
    color: var(--text-muted);
    padding: 2rem;
    border: 2px dashed var(--border);
    border-radius: 12px;
  }
</style>
